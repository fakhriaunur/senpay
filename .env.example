# PostgreSQL (env var: DATABASE_URL)
# Copy .env.example to .env and set DATABASE_URL before running.
# See docker-compose.yml for local dev defaults.

# Redis
REDIS_URL=redis://localhost:6379

# NATS
NATS_URL=nats://localhost:4222

# JWT
JWT_SECRET=change-me-in-production

# Feature flags
SENPAI_FULL_ENABLED=false

# LLM nudge tips (optional, feature-gated)
# Provider: "disabled" (default, no-op), "openai-compatible", "openai", "anthropic"
# SENPAI_LLM_PROVIDER=disabled
# SENPAI_LLM_BASE_URL=https://api.openai.com
# SENPAI_LLM_API_KEY=
# SENPAI_LLM_MODEL=gpt-4o

# Bank adapter: "stub" (canned, no network) or "snap" (real SNAP protocol via mock bank HTTP)
BANK_PROVIDER=stub
